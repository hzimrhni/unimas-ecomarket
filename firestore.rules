rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/User/$(request.auth.uid)).data.role == 'admin';
    }

    match /User/{userId} {
      // Students can create their own profile once during onboarding.
      allow create: if isOwner(userId) &&
        !exists(/databases/$(database)/documents/User/$(userId));

      // Signed-in users can read seller/student profiles used by marketplace UI.
      allow read: if isSignedIn();

      // Users can update their own profile state, and admins can manage any user.
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /User/{userId}/Cart/{listingId} {
      allow read, create, update: if isOwner(userId);
      allow delete: if isOwner(userId) || (
        isSignedIn() &&
        exists(/databases/$(database)/documents/Listing/$(listingId)) &&
        get(/databases/$(database)/documents/Listing/$(listingId)).data.seller_id == request.auth.uid
      );
    }

    match /Category/{categoryId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /Category/{categoryId}/SubCategory/{subCategoryId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /Listing/{listingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.seller_id == request.auth.uid;
      allow update, delete: if isAdmin() ||
        (isSignedIn() && resource.data.seller_id == request.auth.uid);
    }

    match /Report/{reportId} {
      allow create: if isSignedIn() &&
        request.resource.data.reporter_id == request.auth.uid;
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.reporter_id == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /Review/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.reviewer_id == request.auth.uid;
      allow update: if isSignedIn() &&
        resource.data.reviewer_id == request.auth.uid &&
        request.resource.data.reviewer_id == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /Chat/{chatId} {
      allow create: if isSignedIn() &&
        request.resource.data.buyer_id == request.auth.uid;
      allow read, update: if isSignedIn() &&
        (resource.data.buyer_id == request.auth.uid ||
         resource.data.seller_id == request.auth.uid);
      allow delete: if false;
    }

    match /Chat/{chatId}/ChatMessage/{messageId} {
      allow create: if isSignedIn() &&
        exists(/databases/$(database)/documents/Chat/$(chatId)) &&
        (get(/databases/$(database)/documents/Chat/$(chatId)).data.buyer_id == request.auth.uid ||
         get(/databases/$(database)/documents/Chat/$(chatId)).data.seller_id == request.auth.uid);
      allow read: if isSignedIn() &&
        exists(/databases/$(database)/documents/Chat/$(chatId)) &&
        (get(/databases/$(database)/documents/Chat/$(chatId)).data.buyer_id == request.auth.uid ||
         get(/databases/$(database)/documents/Chat/$(chatId)).data.seller_id == request.auth.uid);
      allow update: if isSignedIn() &&
        exists(/databases/$(database)/documents/Chat/$(chatId)) &&
        (get(/databases/$(database)/documents/Chat/$(chatId)).data.buyer_id == request.auth.uid ||
         get(/databases/$(database)/documents/Chat/$(chatId)).data.seller_id == request.auth.uid);
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
